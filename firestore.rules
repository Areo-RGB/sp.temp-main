rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helpers
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Session Blueprint
    function isValidSession(data) {
      return data.keys().hasAll(['status', 'createdAt']) &&
             (data.keys().size() == 2 || (data.keys().size() == 3 && data.keys().hasAny(['startTime']))) &&
             data.status in ['waiting', 'running', 'finished'] &&
             data.createdAt is number &&
             (data.keys().hasAny(['startTime']) ? data.startTime is number : true);
    }
    
    // Client Blueprint
    function isValidClient(data) {
      return data.keys().hasAll(['joinedAt']) &&
             (data.keys().size() == 1 || data.keys().size() == 2 && data.keys().hasAny(['elapsedTime']) || data.keys().size() == 3 && data.keys().hasAny(['elapsedTime', 'deviceName'])) &&
             data.joinedAt is number &&
             (data.keys().hasAny(['elapsedTime']) ? data.elapsedTime is number : true);
    }
    
    match /sessions/{sessionId} {
      allow read, write: if true; // In transient game mode, keep it open but we can still validate shape.
      
      match /clients/{clientId} {
        allow read, write: if true;
      }
    }
  }
}
